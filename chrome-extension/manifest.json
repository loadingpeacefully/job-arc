{
  "manifest_version": 3,
  "name": "Job Arc",
  "version": "1.0",
  "description": "Add LinkedIn jobs to Job Arc in one click",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": [
    "https://www.linkedin.com/jobs/view/*",
    "http://localhost:3000/*",
    "https://jobs-arc.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/view/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
